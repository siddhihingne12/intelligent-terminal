#!/usr/bin/env bash
# PostToolUse hook — forward tool-completed event to Windows Terminal
set -euo pipefail

[ -z "${WT_COM_CLSID:-}" ] && exit 0
command -v wtcli >/dev/null 2>&1 || exit 0

INPUT="$(cat)"
[ -z "$INPUT" ] && exit 0

if [ -n "${COPILOT_CLI:-}" ]; then SRC="copilot"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then SRC="claude"
else SRC="unknown"; fi

export WTA_CLI_SOURCE="$SRC"

# Extract agent_session_id from stdin JSON; fallback to env vars; empty default.
AGENT_SESSION_ID=""
if command -v python3 >/dev/null 2>&1; then
    AGENT_SESSION_ID="$(printf '%s' "$INPUT" | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("session_id",""))' 2>/dev/null || true)"
fi
if [ -z "$AGENT_SESSION_ID" ]; then
    AGENT_SESSION_ID="${COPILOT_SESSION_ID:-${CLAUDE_SESSION_ID:-${GEMINI_SESSION_ID:-}}}"
fi

# Build the wrapped payload safely via python3 to avoid JSON injection on
# untrusted fields (SRC, AGENT_SESSION_ID, INPUT). Falls back to a minimal
# env-only payload if python3 is unavailable.
export SRC AGENT_SESSION_ID
WRAPPED=""
if command -v python3 >/dev/null 2>&1; then
    WRAPPED="$(printf '%s' "$INPUT" | python3 -c '
import sys, json, os
try:
    raw = sys.stdin.read()
    payload = json.loads(raw) if raw.strip() else {}
except Exception:
    payload = {}
print(json.dumps({
    "cli_source": os.environ.get("SRC", ""),
    "agent_session_id": os.environ.get("AGENT_SESSION_ID", ""),
    "payload": payload,
}))
' 2>/dev/null || true)"
fi
if [ -z "$WRAPPED" ]; then
    WRAPPED="{\"cli_source\":\"$SRC\",\"agent_session_id\":\"\",\"payload\":{}}"
fi

wtcli send-event -e "agent.tool.completed" "$WRAPPED" 2>/dev/null || true
exit 0
