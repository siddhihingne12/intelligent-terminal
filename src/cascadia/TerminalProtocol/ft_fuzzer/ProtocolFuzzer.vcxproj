<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <ProjectGuid>{26711D2F-CA10-45BE-9E89-43771030BDB0}</ProjectGuid>
    <Keyword>Win32Proj</Keyword>
    <RootNamespace>ProtocolFuzzer</RootNamespace>
    <ProjectName>Protocol.Fuzzer</ProjectName>
    <TargetName>ProtocolFuzzer</TargetName>
    <ConfigurationType>Application</ConfigurationType>
  </PropertyGroup>
  <Import Project="..\..\..\common.build.pre.props" />
  <Import Project="..\..\..\common.nugetversions.props" />
  <ItemGroup>
    <ClInclude Include="precomp.h" />
    <ClInclude Include="..\ProtocolParsing.h" />
  </ItemGroup>
  <ItemGroup>
    <ClCompile Include="precomp.cpp">
      <PrecompiledHeader>Create</PrecompiledHeader>
      <DebugInformationFormat>ProgramDatabase</DebugInformationFormat>
    </ClCompile>
    <ClCompile Include="fuzzmain.cpp" />
  </ItemGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <AdditionalIncludeDirectories>..;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ClCompile>
    <Link>
      <SubSystem>Console</SubSystem>
    </Link>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Fuzzing'">
    <!-- Only link the fuzzer runtime when building for Fuzzing. In non-Fuzzing
         builds a normal main() is used for manual testing with input files. -->
    <Link>
      <AdditionalDependencies>clang_rt.fuzzer_MT-$(OCClangArchitectureName).lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>
  <!-- Careful reordering these. Some default props (contained in these files) are order sensitive. -->
  <Import Project="..\..\..\common.build.post.props" />
  <Import Project="..\..\..\common.nugetversions.targets" />
</Project>
